      <script>
      (function(){
        var deadlineMs = typeof learnsimplyPromoDeadline !== 'undefined' ? parseInt(learnsimplyPromoDeadline) : 0;
        if(!deadlineMs){
          var fallback = new Date();
          fallback.setDate(fallback.getDate() + 3);
          fallback.setHours(23,59,59,0);
          deadlineMs = fallback.getTime();
        }
        function pad(n){ return String(n).padStart(2,'0'); }
        function tick(){
          var diff = deadlineMs - Date.now();
          if(diff <= 0){
            document.getElementById('ls-cta-days').textContent='00';
            document.getElementById('ls-cta-hours').textContent='00';
            document.getElementById('ls-cta-mins').textContent='00';
            document.getElementById('ls-cta-secs').textContent='00';
            return;
          }
          document.getElementById('ls-cta-days').textContent = pad(Math.floor(diff/(1000*60*60*24)));
          document.getElementById('ls-cta-hours').textContent = pad(Math.floor((diff%(1000*60*60*24))/(1000*60*60)));
          document.getElementById('ls-cta-mins').textContent = pad(Math.floor((diff%(1000*60*60))/(1000*60)));
          document.getElementById('ls-cta-secs').textContent = pad(Math.floor((diff%(1000*60))/1000));
        }
        tick();
        setInterval(tick, 1000);
      })();
      </script>
